DISCORD_TOP_PICKS_CHANNEL_ID=

# LLM for AI agents (default groq; also anthropic, openai)
LLM_PROVIDER=groq
GROQ_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
AGENT_MODEL=openai/gpt-oss-120b
COMMENTARY_MODEL=openai/gpt-oss-20b
