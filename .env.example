BETFAIR_APP_KEY=
BETFAIR_USERNAME=
BETFAIR_PASSWORD=
BETFAIR_CERT_FILE=~/.betfair/client-2048.crt
BETFAIR_KEY_FILE=~/.betfair/client-2048.key
DB_PATH=./racing.duckdb
RAW_DATA_DIR=./data/raw

# Discord publishing (Paddock Edge)
DISCORD_BOT_TOKEN=
DISCORD_PICKS_CHANNEL_ID=
DISCORD_RESULTS_CHANNEL_ID=
